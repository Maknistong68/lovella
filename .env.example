# Optional: add these to enable Supabase storage of responses.
# Copy this file to ".env" and fill in your project values.
# Without these, responses are saved to the browser's localStorage instead.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: get pinged the instant she answers.
# Works with a Discord webhook URL, or a Telegram bot sendMessage URL, etc.
# Leave blank to disable.
VITE_NOTIFY_WEBHOOK=
